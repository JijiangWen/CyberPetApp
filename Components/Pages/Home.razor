@page "/"
@attribute [Authorize]
@using CyberPetApp.Models
@using CyberPetApp.Services
@using System.Security.Claims
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>CYBERPET OS</PageTitle>

@if (isSessionKicked)
{
    <div class="kicked-screen">
        <div class="kicked-logo">⚠️ CONNECTION CONFLICT</div>
        <div class="kicked-msg">检测到您的账号已在其他标签页/窗口登录。</div>
        <div class="kicked-hint">本窗口的游戏模拟与挂机操作已自动暂停，以防止数据冲突。</div>
        <button class="g-btn primary" onclick="window.location.reload();">重新连接并登录</button>
    </div>
}
else if (isLoading || player is null)
{
    <div class="loading-screen">
        <div class="loading-logo">◈ CYBERPET OS</div>
        <div class="loading-bar"><div class="loading-bar-fill"></div></div>
        <div class="loading-msg">reading save data...</div>
    </div>
}
else
{
<CascadingValue Value="gameSession" IsFixed="true">
<div class="geek-root @(showScanlines ? "crt-scanlines" : "") theme-@currentTheme">

    <!-- ══ Titlebar ══ -->
    <div class="titlebar">
        <span class="titlebar-title">◈ CYBERPET OS</span>
        <span class="titlebar-sep">│</span>
        <span class="titlebar-stat"><PixelIcon Name="user" /><span class="v">@username</span></span>
        <span class="titlebar-sep">·</span>
        <span class="titlebar-stat"><PixelIcon Name="coin" /><span class="v">@player.Money g</span></span>
        <span class="titlebar-sep mobile-hide">·</span>
        <span class="titlebar-stat mobile-hide"><PixelIcon Name="bag" /><span class="v">@BackpackTotalCount()</span></span>
        <span class="titlebar-sep mobile-hide">·</span>
        <span class="titlebar-stat mobile-hide"><PixelIcon Name="house" /><span class="v">lv.@playerHouse.House_Level</span></span>
        <div class="titlebar-spacer"></div>
        <span class="titlebar-pill @(player.IsWorking ? "active" : "")">
            @(player.IsWorking ? "⚙ WORKING" : "○ IDLE")
        </span>
        <span class="titlebar-pill @(fishingManager.IsFishing ? "active" : "")">
            @(fishingManager.IsFishing ? "◎ FISHING" : "— FISH")
        </span>
        <button type="button" class="titlebar-settings-btn" @onclick="ToggleSettings" title="Game Settings">
            <PixelIcon Name="settings" />
        </button>
    </div>

    <!-- ══ Body ══ -->
    <div class="geek-body">

        <!-- ═ Sidebar ═ -->
        <aside class="sidebar">
            <CatCareSidebar @key="tickGeneration"
                            Vitals="catVitalsSnapshot"
                            Player="player"
                            CatSkinId="@cat.CurrentSkinId"
                            DebuffLines="_sidebarDebuffLines"
                            PassiveSummary="PassiveCareSummaryLines()"
                            ActiveFoodBuffs="activeFoodBuffs"
                            HasFood="HasBackpackFood"
                            OnFeed="FeedShopFood"
                            OnFeedCooked="FeedCookedFood"
                            OnDrink="ManualDrinkWater"
                            OnStroke="ManualStroke"
                            OnSleep="ManualSleep"
                            OnTreat="TreatCat" />
        </aside>

        <!-- ═ Main area ═ -->
        <div class="main-area @(isMobileTabExpanded ? "tab-expanded" : "")">

            @if (catchBroadcast is not null)
            {
                <div class="catch-broadcast @(catchBroadcastMyth ? "myth" : catchBroadcastLegendary ? "legendary" : "")">
                    <span class="cb-icon">@(catchBroadcastMyth ? "☆" : catchBroadcastLegendary ? "✦" : "◎")</span>
                    <span class="cb-text">@catchBroadcast</span>
                    <button class="cb-dismiss" @onclick="DismissCatchBroadcast">×</button>
                </div>
            }
            @if (offlineMessage is not null)
            {
                <div class="offline-banner">
                    // @offlineMessage
                    <span class="offline-cap-hint"> · 离线补偿上限 1 小时 / @OfflineCompensationService.MaxOfflineTicks tick（不含钓鱼）</span>
                </div>
            }

            <div class="tab-strip tab-strip-grouped @(isMobileTabExpanded ? "expanded" : "")">
                <button type="button" class="tab-toggle-btn mobile-only" @onclick="ToggleMobileTabs" title="Toggle Sidebar">
                    <span>@(isMobileTabExpanded ? "«" : "»")</span>
                </button>
                <div class="tab-group tab-group-core">
                    <span class="tab-group-label">核心</span>
                    <button class="g-tab mobile-only-tab @(activeSection=="cat"?"active":"")"
                            @onclick='()=>SelectSectionAsync("cat")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="cat" />
                        <span class="tab-text">
                            <span class="tab-cn">猫咪</span>
                            <span class="tab-en">cat.status</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="house"?"active":"")"
                            @onclick='()=>SelectSectionAsync("house")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="house" />
                        <span class="tab-text">
                            <span class="tab-cn">家园</span>
                            <span class="tab-en">home.room</span>
                        </span>
                    </button>
                </div>
                <div class="tab-group tab-group-activity">
                    <span class="tab-group-label">活动</span>
                    <button class="g-tab @(activeSection=="fishing"?"active":"")"
                            @onclick='()=>SelectSectionAsync("fishing")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="fish" />
                        <span class="tab-text">
                            <span class="tab-cn">钓鱼</span>
                            <span class="tab-en">fishing.spot</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="work"?"active":"")"
                            @onclick='()=>SelectSectionAsync("work")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="hammer" />
                        <span class="tab-text">
                            <span class="tab-cn">打工</span>
                            <span class="tab-en">work.proc</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="expedition"?"active":"")"
                            @onclick='()=>SelectSectionAsync("expedition")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="cat" />
                        <span class="tab-text">
                            <span class="tab-cn">派遣</span>
                            <span class="tab-en">exped.dispatch</span>
                        </span>
                    </button>
                    <button class="g-tab market-tab @(activeSection=="market"?"active":"") @(PendingOfferCount()>0?"has-offers":"")"
                            @onclick='()=>SelectSectionAsync("market")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="shop" />
                        <span class="tab-text">
                            <span class="tab-cn">鱼市</span>
                            <span class="tab-en">market.stall</span>
                        </span>
                        @if (PendingOfferCount() > 0)
                        {
                            <span class="tab-badge">@PendingOfferCount()</span>
                        }
                    </button>
                    <button class="g-tab @(activeSection=="boat"?"active":"")"
                            @onclick='()=>SelectSectionAsync("boat")' title="联机小船">
                        <span class="t-dot"></span>
                        <i class="bi bi-anchor" style="font-size: 14px; margin-right: 4px;"></i>
                        <span class="tab-text">
                            <span class="tab-cn">联机小船</span>
                            <span class="tab-en">multiplayer.boat</span>
                        </span>
                    </button>
                </div>
                <div class="tab-group tab-group-growth">
                    <span class="tab-group-label">成长</span>
                    <button class="g-tab @(activeSection=="gear"?"active":"")"
                            @onclick='()=>SelectSectionAsync("gear")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="rod" />
                        <span class="tab-text">
                            <span class="tab-cn">装备</span>
                            <span class="tab-en">gear.loadout</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="cooking"?"active":"")"
                            @onclick='()=>SelectSectionAsync("cooking")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="food" />
                        <span class="tab-text">
                            <span class="tab-cn">烹饪</span>
                            <span class="tab-en">cook.lab</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="alchemy"?"active":"")"
                            @onclick='()=>SelectSectionAsync("alchemy")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="alchemy" />
                        <span class="tab-text">
                            <span class="tab-cn">炼金</span>
                            <span class="tab-en">alchemy.lab</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="lifeshop"?"active":"")"
                        @onclick='() => SelectSectionAsync("lifeshop")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="shop" />
                        <span class="tab-text">
                            <span class="tab-cn">生活商店</span>
                            <span class="tab-en">shop.market</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="catskin"?"active":"")"
                        @onclick='() => SelectSectionAsync("catskin")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="palette" />
                        <span class="tab-text">
                            <span class="tab-cn">外观</span>
                            <span class="tab-en">cat.skin</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="milestones"?"active":"")"
                            @onclick='()=>SelectSectionAsync("milestones")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="milestone" />
                        <span class="tab-text">
                            <span class="tab-cn">里程碑</span>
                            <span class="tab-en">mile.stone</span>
                        </span>
                    </button>
                    <button class="g-tab @(activeSection=="backpack"?"active":"")"
                            @onclick='()=>SelectSectionAsync("backpack")'>
                        <span class="t-dot"></span>
                        <PixelIcon Name="bag" />
                        <span class="tab-text">
                            <span class="tab-cn">背包</span>
                            <span class="tab-en">bag.inv</span>
                        </span>
                    </button>
                </div>
            </div>

            <div class="content-scroll">
            @switch (activeSection)
            {
                case "cat":
                <div class="mobile-cat-tab-content">
                    <CatCareSidebar @key="tickGeneration"
                                    Vitals="catVitalsSnapshot"
                                    Player="player!"
                                    CatSkinId="@cat.CurrentSkinId"
                                    DebuffLines="_sidebarDebuffLines"
                                    PassiveSummary="PassiveCareSummaryLines()"
                                    ActiveFoodBuffs="activeFoodBuffs"
                                    HasFood="HasBackpackFood"
                                    OnFeed="FeedShopFood"
                                    OnFeedCooked="FeedCookedFood"
                                    OnDrink="ManualDrinkWater"
                                    OnStroke="ManualStroke"
                                    OnSleep="ManualSleep"
                                    OnTreat="TreatCat" />
                </div>
                break;
                case "house":
                <HomeHouseTab HouseBuffs="GetHouseBuffs()"
                              CatState="@CatState()"
                              CatSkinId="@cat.CurrentSkinId"
                              NormalFood="normalFood"
                              LuxuryFood="luxuryFood"
                              FeedMessage="feedMessage"
                              OnBuy="BuyFurniture"
                              OnUpgrade="UpgradeFurniture"
                              OnUnlockRoom="UnlockRoom"
                              OnAddFood="AddFoodToFeeder"
                              OnAddCookedFood="AddCookedFoodToFeeder"
                              OnRemoveFood="RemoveLastFromFeeder"
                              OnAddWater="AddPurifiedWaterToWaterer"
                              OnRemoveWater="RemoveLastFromWaterer"
                              OnBatchFillFood="BatchFillFeeder"
                              OnBatchFillWater="BatchFillWaterer"
                              OnUnlockAutoRefill="UnlockAutoRefill"
                              OnToggleAutoRefill="ToggleAutoRefill"
                              @bind-SelectedRoomKey="CurrentSelectedRoomKey" />
                break;
                case "fishing":
                <HomeFishingTab IsActive="@(activeSection == "fishing")"
                                TickGeneration="tickGeneration"
                                CatBuffLines="FishingCatBuffLines"
                                Username="username"
                                DexEntries="_fishDexCache"
                                FishingBlockMessage="fishingBlockMessage"
                                SpotLicenseMessage="spotLicenseMessage"
                                TopFishLeaderboard="topFishLeaderboard"
                                TopLevelLeaderboard="topLevelLeaderboard"
                                ServerFishingStats="serverFishingStats"
                                LeaderboardRefreshing="leaderboardRefreshing"
                                HasSpotAccess="HasSpotAccess"
                                OnStartFishing="StartFishingAsync"
                                OnStopFishing="StopFishing"
                                OnPaySpotRental="PaySpotRental"
                                OnBuySpotPermanent="BuySpotPermanent"
                                OnRefreshLeaderboard="RefreshLeaderboardManualAsync" />
                break;
                case "gear":
                <HomeGearTab IsActive="@(activeSection == "gear")"
                             TickGeneration="tickGeneration"
                             DexEntries="_fishDexCache"
                             PlayerGems="playerGems"
                             PlayerTargetLures="playerTargetLures"
                             Rods="myRods"
                             Reels="myReels"
                             Lines="myLines"
                             Lures="myLures"
                             GearMessage="gearMessage"
                             OnSocketGem="HandleLoadoutSocketGem"
                             OnEquipTargetLure="EquipTargetLureForGear"
                             OnUnequipTargetLure="UnequipTargetLureForGear"
                             OnGoAlchemy="GoAlchemyFromGear"
                             OnBuyRodCommitted="FinalizeBuyRod"
                             OnBuyReelCommitted="FinalizeBuyReel"
                             OnBuyLineCommitted="FinalizeBuyLine"
                             OnBuyLureCommitted="FinalizeBuyLure"
                             OnEquipRodCommitted="FinalizeEquipRod"
                             OnEquipReelCommitted="FinalizeEquipReel"
                             OnEquipLineCommitted="FinalizeEquipLine"
                             OnEquipLureCommitted="FinalizeEquipLure"
                             OnRepairRodCommitted="FinalizeRepairRod"
                             OnRepairReelCommitted="FinalizeRepairReel"
                             OnRepairLineCommitted="FinalizeRepairLine"
                             OnBuyAutoRepairCommitted="FinalizeBuyAutoRepair"
                             OnToggleAutoRepairCommitted="FinalizeToggleAutoRepair"
                             OnChangeAutoRepairThresholdCommitted="FinalizeChangeAutoRepairThreshold" />
                break;
                case "cooking":
                <HomeCookingTab IsActive="@(activeSection == "cooking")"
                                TickGeneration="tickGeneration"
                                HouseBuffs="GetHouseBuffs()"
                                Message="cookMessage"
                                OnCookAllCommitted="FinalizeCookAll"
                                OnCookFishCommitted="FinalizeCookFish"
                                OnFeedCookedFood="FeedCookedFood" />
                break;
                case "alchemy":
                <HomeAlchemyTab IsActive="@(activeSection == "alchemy")"
                                TickGeneration="tickGeneration"
                                DexEntries="_fishDexCache"
                                PlayerGems="playerGems"
                                PlayerTargetLures="playerTargetLures"
                                Rods="myRods"
                                Reels="myReels"
                                Lines="myLines"
                                Lures="myLures"
                                HasSpotAccess="HasSpotAccess"
                                Message="alchemyMessage"
                                OnCraftGem="CraftGem"
                                OnCraftLine="CraftLine"
                                OnCraftGear="CraftGear"
                                OnCraftTargetLure="CraftTargetLure"
                                OnSocketGem="SocketGemFromTab"
                                OnEquipTargetLure="EquipTargetLure"
                                OnUnequipTargetLure="UnequipTargetLure" />
                break;
                case "lifeshop":
                <HomeLifeShopTab IsActive="@(activeSection == "lifeshop")"
                                 TickGeneration="tickGeneration"
                                 Shop="shop"
                                 Message="lifeShopMessage"
                                 OnBuyItemCommitted="FinalizeBuyShopItem" />
                break;
                case "catskin":
                <CatSkinPanel Player="player!" Cat="cat" OnChanged="SaveSkinAndRefreshAsync" />
                break;
                case "expedition":
                <HomeExpeditionTab IsActive="@(activeSection == "expedition")"
                                   TickGeneration="tickGeneration"
                                   HouseBuffs="GetHouseBuffs()"
                                   OnChanged="RefreshAfterExpeditionAsync" />
                break;
                case "work":
                <HomeWorkTab IsActive="@(activeSection == "work")"
                             TickGeneration="tickGeneration"
                             WorkingPlace="workingPlace"
                             WorkGoldPerTick="@EffectiveWorkGoldPerTick()"
                             StallTicketTicks="@EffectiveStallTicketTicks()"
                             StallTickets="@StallTicketCount()"
                             WorkJobHint="@WorkJobHint()"
                             OnSelectJob="SelectWorkJob"
                             OnToggleWork="ToggleWork" />
                break;
                case "market":
                <HomeMarketTab IsActive="@(activeSection == "market")"
                               TickGeneration="tickGeneration"
                               MarketListings="marketListings"
                               PendingOffers="@PendingOfferCount()"
                               StallTickets="@StallTicketCount()"
                               ListingLimit="@MarketListingLimit()"
                               Message="marketMessage"
                               OnRefreshBounty="RefreshBounty"
                               OnDelist="FinalizeDelistFish"
                               OnAcceptOffer="AcceptOffer"
                               OnCounterOffer="CounterOffer"
                               OnRejectOffer="RejectOffer"
                               OnListFishCommitted="FinalizeListFish" />
                break;
                case "milestones":
                <HomeMilestonesTab IsActive="@(activeSection == "milestones")"
                                   TickGeneration="tickGeneration"
                                   AchievementViews="achievementViews"
                                   MilestoneUnlockIds="milestoneUnlockIds"
                                   GraduationPercent="@GetGraduationPercent()"
                                   Message="milestoneMessage"
                                   OnGoToLeaderboard="GoToLeaderboardAsync"
                                   OnClaimAchievement="ClaimAchievement"
                                   OnBuyMilestoneItem="BuyMilestoneItem" />
                break;
                case "backpack":
                <HomeBackpackTab IsActive="@(activeSection == "backpack")"
                                 TickGeneration="tickGeneration"
                                 TotalCount="@BackpackTotalCount()"
                                 OnFeedCookedFood="FeedCookedFood"
                                 OnSellFish="SellFish"
                                 OnDisassembleFish="DisassembleFish"
                                 OnListFishOnMarket="ListFishOnMarket"
                                 OnGoToMarket="GoToMarketFromBackpack"
                                 OnUpgradeBackpack="HandleUpgradeBackpack" />
                break;
                case "boat":
                <HomeBoatTab />
                break;

            }

            </div><!-- content-scroll -->
        </div><!-- main-area -->
    </div><!-- geek-body -->

    <!-- ══ Status bar ══ -->
    <div class="statusbar">
        <span class="sb-item"><span class="mobile-hide">◈ CYBERPET OS</span><span class="mobile-only">◈</span></span>
        <span class="sb-sep mobile-hide">│</span>
        <span class="sb-item mobile-hide">utf-8</span>
        <span class="sb-sep mobile-hide">│</span>
        <span class="sb-item mobile-hide">@(player.IsWorking ? "⚙ work: on" : "○ work: off")</span>
        <span class="sb-sep mobile-hide">│</span>
        <span class="sb-item mobile-hide">@(fishingManager.IsFishing ? "◎ fishing: on" : "— fishing: off")</span>
        <div class="sb-right">
            <span class="sb-item">tab: @SectionTabLabel(activeSection)</span>
            <span class="sb-sep">│</span>
            <span class="sb-item"><span class="sb-key">鱼市</span> @(PendingOfferCount() > 0 ? $"待处理 {PendingOfferCount()} 条" : "")</span>
        </div>
    </div>

    @if (isSettingsOpen)
    {
        <div class="settings-modal-overlay" @onclick="ToggleSettings">
            <div class="settings-modal-card" @onclick:stopPropagation="true">
                <div class="settings-modal-header">
                    <span class="settings-modal-title">◈ SYSTEM.config — 设置</span>
                    <button type="button" class="settings-close-btn" @onclick="ToggleSettings">&times;</button>
                </div>
                <div class="settings-modal-body">
                    <div class="settings-section">
                        <div class="settings-section-title">// display.settings</div>
                        <div class="settings-row">
                            <label class="settings-label">Accent Theme (主题色)</label>
                            <div class="theme-picker">
                                <button class="theme-opt blue @(currentTheme == "blue" ? "active" : "")" @onclick='() => currentTheme = "blue"'>BLUE</button>
                                <button class="theme-opt green @(currentTheme == "green" ? "active" : "")" @onclick='() => currentTheme = "green"'>GREEN</button>
                                <button class="theme-opt amber @(currentTheme == "amber" ? "active" : "")" @onclick='() => currentTheme = "amber"'>AMBER</button>
                                <button class="theme-opt crimson @(currentTheme == "crimson" ? "active" : "")" @onclick='() => currentTheme = "crimson"'>CRIMSON</button>
                            </div>
                        </div>
                        <div class="settings-row">
                            <label class="settings-label">CRT Scanline Overlay (扫描线滤镜)</label>
                            <div class="toggle-switch">
                                <button class="toggle-btn @(showScanlines ? "active" : "")" @onclick="() => showScanlines = true">ON</button>
                                <button class="toggle-btn @(!showScanlines ? "active" : "")" @onclick="() => showScanlines = false">OFF</button>
                            </div>
                        </div>
                    </div>

                    <div class="settings-section">
                        <div class="settings-section-title">// audio.settings</div>
                        <div class="settings-row">
                            <label class="settings-label">Game Sound Effects (音效)</label>
                            <div class="toggle-switch">
                                <button class="toggle-btn @(enableSfx ? "active" : "")" @onclick="() => enableSfx = true">ON</button>
                                <button class="toggle-btn @(!enableSfx ? "active" : "")" @onclick="() => enableSfx = false">OFF</button>
                            </div>
                        </div>
                    </div>

                    <div class="settings-section">
                        <div class="settings-section-title">// account.profile</div>
                        <div class="settings-row info-row">
                            <span class="info-label">Username (当前账号):</span>
                            <span class="info-val">@username</span>
                        </div>
                        <div class="settings-row info-row">
                            <span class="info-label">Player Level (等级):</span>
                            <span class="info-val">lv.@playerHouse.House_Level</span>
                        </div>
                        <div class="settings-row info-row">
                            <span class="info-label">Balance (金币):</span>
                            <span class="info-val" style="color:var(--gold);">@player.Money g</span>
                        </div>
                    </div>

                    <div class="settings-actions">
                        <form method="post" action="/api/auth/logout">
                            <button type="submit" class="g-btn danger" style="width: 100%; height: 32px; font-weight: bold;">LOGOUT (退出登录)</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

</div>
</CascadingValue>
}
