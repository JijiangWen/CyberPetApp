            </svg>
            break;
        case "coin":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="2" width="6" height="1" fill="#ffcc66"/><rect x="4" y="3" width="8" height="1" fill="#f5a833"/>
                <rect x="3" y="4" width="10" height="8" fill="#e8841a"/><rect x="4" y="4" width="8" height="1" fill="#ffcc66"/>
                <rect x="3" y="5" width="1" height="6" fill="#c46e10"/><rect x="12" y="5" width="1" height="6" fill="#a05808"/>
                <rect x="4" y="12" width="8" height="1" fill="#c46e10"/><rect x="5" y="13" width="6" height="1" fill="#a05808"/>
                <rect x="7" y="7" width="2" height="2" fill="#ffcc66"/>
            </svg>
            break;
        case "shop":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="4" width="14" height="1" fill="#c46e10"/><rect x="2" y="3" width="12" height="1" fill="#e8841a"/><rect x="3" y="2" width="10" height="1" fill="#f5a833"/>
                <rect x="2" y="5" width="12" height="8" fill="#7a5c3e"/><rect x="3" y="5" width="10" height="1" fill="#9a7348"/>
                <rect x="4" y="8" width="3" height="4" fill="#4a3228"/><rect x="9" y="8" width="3" height="4" fill="#4a3228"/>
                <rect x="5" y="9" width="1" height="2" fill="#f5a833"/><rect x="10" y="9" width="1" height="2" fill="#6ec8d8"/>
            </svg>
            break;
        case "rod":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="13" y="1" width="1" height="1" fill="#9a7348"/><rect x="12" y="2" width="1" height="1" fill="#7a5c3e"/><rect x="11" y="3" width="1" height="1" fill="#7a5c3e"/>
                <rect x="10" y="4" width="1" height="1" fill="#5c4033"/><rect x="9" y="5" width="1" height="1" fill="#5c4033"/><rect x="8" y="6" width="1" height="1" fill="#4a3228"/>
                <rect x="7" y="7" width="1" height="1" fill="#4a3228"/><rect x="6" y="8" width="1" height="1" fill="#4a3228"/><rect x="5" y="9" width="1" height="1" fill="#3a2818"/>
                <rect x="4" y="10" width="1" height="1" fill="#3a2818"/><rect x="3" y="11" width="1" height="1" fill="#3a2818"/><rect x="2" y="12" width="1" height="1" fill="#2a1810"/>
                <rect x="14" y="2" width="1" height="3" fill="#6ec8d8"/>
            </svg>
            break;
        case "hammer":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="2" width="6" height="3" fill="#6a7080"/><rect x="3" y="2" width="4" height="1" fill="#8a90a0"/>
                <rect x="7" y="4" width="2" height="2" fill="#9a7348"/><rect x="8" y="6" width="1" height="8" fill="#7a5c3e"/>
                <rect x="7" y="7" width="1" height="1" fill="#5c4033"/>
            </svg>
            break;
        case "bowl":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="4" y="5" width="8" height="1" fill="#8a90a0"/><rect x="3" y="6" width="10" height="1" fill="#6a7080"/>
                <rect x="3" y="7" width="10" height="4" fill="#4a5060"/><rect x="4" y="7" width="8" height="1" fill="#6a7080"/>
                <rect x="4" y="8" width="8" height="2" fill="#c46e10"/><rect x="5" y="8" width="6" height="1" fill="#e8841a"/>
                <rect x="4" y="11" width="8" height="1" fill="#3a3f4f"/>
            </svg>
            break;
        case "food":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="3" width="6" height="1" fill="#c46e10"/><rect x="4" y="4" width="8" height="7" fill="#a05808"/>
                <rect x="5" y="4" width="6" height="1" fill="#e8841a"/><rect x="5" y="6" width="6" height="4" fill="#7a4a20"/>
                <rect x="6" y="7" width="1" height="1" fill="#5c3010"/><rect x="8" y="8" width="1" height="1" fill="#5c3010"/><rect x="10" y="7" width="1" height="1" fill="#5c3010"/>
            </svg>
            break;
        case "water":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="7" y="2" width="2" height="1" fill="#6ec8d8"/><rect x="6" y="3" width="4" height="1" fill="#5ca8b8"/>
                <rect x="5" y="4" width="6" height="1" fill="#4a8a9a"/><rect x="5" y="5" width="6" height="6" fill="#3a6a78"/>
                <rect x="6" y="5" width="4" height="1" fill="#5ca8b8"/><rect x="7" y="7" width="2" height="2" fill="#6ec8d8"/>
            </svg>
            break;
        case "star":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="7" y="2" width="2" height="1" fill="#ffcc66"/><rect x="6" y="3" width="4" height="1" fill="#f5a833"/>
                <rect x="2" y="5" width="12" height="2" fill="#f5a833"/><rect x="5" y="4" width="6" height="1" fill="#ffcc66"/>
                <rect x="3" y="7" width="2" height="3" fill="#e8841a"/><rect x="11" y="7" width="2" height="3" fill="#e8841a"/>
                <rect x="5" y="7" width="6" height="4" fill="#f5a833"/><rect x="6" y="8" width="4" height="2" fill="#ffcc66"/>
                <rect x="4" y="11" width="3" height="2" fill="#c46e10"/><rect x="9" y="11" width="3" height="2" fill="#c46e10"/>
