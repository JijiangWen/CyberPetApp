@using CyberPetApp.Models
@using CyberPetApp.Services
@implements IDisposable

@if (Manager.IsFishing || Manager.EventLog.Count > 0)
{
    <div class="section-tw tw">
        <div class="tw-header">
            <span class="tw-icon green"></span>
            RUNTIME.session
        </div>
        <div class="tw-body">
            @if (Manager.IsFishing)
            {
                <div class="phase-box phase-@Manager.State.ToString().ToLower()">
                    <div class="phase-text">@Manager.StatusText</div>
                    @if (Manager.State == FishingState.Waiting)
                    {
                        <div class="s-row" style="font-family: monospace; display: flex; flex-direction: column; gap: 4px; margin-top: 6px;">
                            <div style="display: flex; justify-content: space-between; font-size: 11px; align-items: center;">
                                <span style="color: #8892b0;">已抛竿: <span style="color: #00f3ff; font-weight: bold;">@FormatElapsed(Manager.PhaseTotalSeconds - Manager.PhaseRemainingSeconds)</span></span>
                                <span style="color: #8892b0;">水面状态: <span style="color: @(Manager.IsFakeBiting ? "#ff007f" : "#39ff14"); font-weight: bold;">@GetWaterState(Manager.IsFakeBiting, Manager.PhaseRemainingSeconds, Manager.PhaseTotalSeconds)</span></span>
                            </div>
                            <div style="color: #00f3ff; letter-spacing: 2px; font-size: 11px; text-shadow: 0 0 5px #00f3ff; padding: 4px; background: rgba(0, 0, 0, 0.2); border-radius: 4px; border: 1px solid rgba(0, 243, 255, 0.08); text-align: center;">
                                @GetWaterVisual(Manager.IsFakeBiting, Manager.PhaseRemainingSeconds, Manager.PhaseTotalSeconds)
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="s-row">
                            <span class="s-label">@PhaseLabel()</span>
                            <code class="abar abar-happy">@PhaseBar()</code>
                            <span class="s-val" style="font-size:10px;">@Manager.PhaseRemainingSeconds.ToString("0.0")s</span>
                        </div>
                    }
                </div>
            }
            @if (Manager.EventLog.Count > 0)
            {
                <div class="log-box">
                    @foreach (var log in Manager.EventLog.TakeLast(5))
                    {
                        <div class="log-line log-@log.Kind">
                             <span class="log-time">[@log.Time.ToString("HH:mm:ss")]</span> @log.Text
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public FishingManager Manager { get; set; } = null!;

    // P0-2：仅状态/日志/阶段秒数显著变化时重绘，避免 250ms 全页 diff
    private FishingState _lastState;
    private double _lastPhaseRemaining = -1;
    private int _lastLogCount;

    protected override void OnInitialized()
    {
        Manager.Changed += OnManagerChanged;
        CaptureSnapshot();
    }

    private void OnManagerChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    protected override bool ShouldRender()
    {
        if (Manager.State != _lastState) return true;
        if (Manager.EventLog.Count != _lastLogCount) return true;
        if (Math.Abs(Manager.PhaseRemainingSeconds - _lastPhaseRemaining) >= 0.5) return true;
        return false;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        CaptureSnapshot();
    }

    private void CaptureSnapshot()
    {
        _lastState = Manager.State;
        _lastPhaseRemaining = Manager.PhaseRemainingSeconds;
        _lastLogCount = Manager.EventLog.Count;
    }

    private string FormatElapsed(double seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        return $"{(int)ts.TotalMinutes:00}:{ts.Seconds:00}";
    }

    private string GetWaterState(bool isFakeBiting, double remaining, double total)
    {
        if (isFakeBiting) return "浮漂轻摇 🐟";
        double elapsed = total - remaining;
        bool showRipples = ((int)elapsed % 7) < 3; // Natural breathing cycle
        return showRipples ? "水波微兴 🍃" : "水平如镜 🌊";
    }

    private string GetWaterVisual(bool isFakeBiting, double remaining, double total)
    {
        if (isFakeBiting) return "🐟 ≈≈ ≈≈ ≈≈ ≈≈ ≈≈ ≈≈ 🐟";
        double elapsed = total - remaining;
        bool showRipples = ((int)elapsed % 7) < 3; // Natural breathing cycle
        return showRipples ? "🍃~ ~ ~ ~ ~ ~ ~ ~ ~ ~" : "🌊░░░░░░░░░░░░░░░░░░░░";
    }

    private string PhaseLabel() => Manager.State switch
    {
        FishingState.Waiting => "wait",
        FishingState.Biting => "hook",
        FishingState.Reeling => "reel",
        _ => "-"
    };

    private string PhaseBar()
    {
        double total = Math.Max(0.001, Manager.PhaseTotalSeconds);
        double done = total - Manager.PhaseRemainingSeconds;
        return ProgressBar((int)(done * 100), (int)(total * 100));
    }

    private static string ProgressBar(int value, int max, int w = 10)
    {
        var f = Math.Clamp((int)Math.Round((double)value / Math.Max(1, max) * w), 0, w);
        return new string('█', f) + new string('░', w - f);
    }

    public void Dispose()
    {
        Manager.Changed -= OnManagerChanged;
    }
}
