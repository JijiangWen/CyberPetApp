@* 16×16 crisp pixel sprites — no anti-alias, no filters *@

<span class="px-icon" role="img" aria-label="@AriaLabel" aria-hidden="@(string.IsNullOrEmpty(AriaLabel))">
    @switch (Name)
    {
        case "moon":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="9" y="1" width="1" height="1" fill="#ffcc66"/><rect x="10" y="1" width="1" height="1" fill="#ffcc66"/>
                <rect x="8" y="2" width="1" height="1" fill="#ffcc66"/><rect x="9" y="2" width="1" height="1" fill="#f5a833"/><rect x="10" y="2" width="1" height="1" fill="#f5a833"/><rect x="11" y="2" width="1" height="1" fill="#e8841a"/>
                <rect x="7" y="3" width="1" height="1" fill="#ffcc66"/><rect x="8" y="3" width="1" height="1" fill="#f5a833"/><rect x="9" y="3" width="1" height="1" fill="#f5a833"/><rect x="10" y="3" width="1" height="1" fill="#e8841a"/><rect x="11" y="3" width="1" height="1" fill="#e8841a"/><rect x="12" y="3" width="1" height="1" fill="#c46e10"/>
                <rect x="6" y="4" width="1" height="1" fill="#f5a833"/><rect x="7" y="4" width="1" height="1" fill="#f5a833"/><rect x="8" y="4" width="1" height="1" fill="#e8841a"/><rect x="9" y="4" width="1" height="1" fill="#e8841a"/><rect x="10" y="4" width="1" height="1" fill="#e8841a"/><rect x="11" y="4" width="1" height="1" fill="#c46e10"/><rect x="12" y="4" width="1" height="1" fill="#c46e10"/>
                <rect x="6" y="5" width="1" height="1" fill="#e8841a"/><rect x="7" y="5" width="1" height="1" fill="#e8841a"/><rect x="8" y="5" width="1" height="1" fill="#c46e10"/><rect x="9" y="5" width="1" height="1" fill="#c46e10"/><rect x="10" y="5" width="1" height="1" fill="#c46e10"/><rect x="11" y="5" width="1" height="1" fill="#a05808"/><rect x="12" y="5" width="1" height="1" fill="#a05808"/>
                <rect x="6" y="6" width="1" height="1" fill="#e8841a"/><rect x="7" y="6" width="1" height="1" fill="#c46e10"/><rect x="8" y="6" width="1" height="1" fill="#c46e10"/><rect x="9" y="6" width="1" height="1" fill="#a05808"/><rect x="10" y="6" width="1" height="1" fill="#c46e10"/><rect x="11" y="6" width="1" height="1" fill="#c46e10"/><rect x="12" y="6" width="1" height="1" fill="#a05808"/>
                <rect x="6" y="7" width="1" height="1" fill="#c46e10"/><rect x="7" y="7" width="1" height="1" fill="#a05808"/><rect x="8" y="7" width="1" height="1" fill="#a05808"/><rect x="9" y="7" width="1" height="1" fill="#a05808"/><rect x="10" y="7" width="1" height="1" fill="#a05808"/><rect x="11" y="7" width="1" height="1" fill="#a05808"/><rect x="12" y="7" width="1" height="1" fill="#804408"/>
                <rect x="7" y="8" width="1" height="1" fill="#c46e10"/><rect x="8" y="8" width="1" height="1" fill="#a05808"/><rect x="9" y="8" width="1" height="1" fill="#a05808"/><rect x="10" y="8" width="1" height="1" fill="#a05808"/><rect x="11" y="8" width="1" height="1" fill="#804408"/>
                <rect x="8" y="9" width="1" height="1" fill="#c46e10"/><rect x="9" y="9" width="1" height="1" fill="#a05808"/><rect x="10" y="9" width="1" height="1" fill="#804408"/>
                <rect x="9" y="10" width="1" height="1" fill="#a05808"/><rect x="10" y="10" width="1" height="1" fill="#804408"/>
            </svg>
            break;
        case "cat":
            <img class="px-icon-img" src="/assets/cat/content.png" width="16" height="16" alt="" />
            break;
        case "fish":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="7" width="1" height="2" fill="#4a8a9a"/><rect x="2" y="6" width="1" height="1" fill="#4a8a9a"/><rect x="2" y="9" width="1" height="1" fill="#4a8a9a"/>
                <rect x="3" y="5" width="1" height="1" fill="#5ca8b8"/><rect x="3" y="10" width="1" height="1" fill="#3a6a78"/>
                <rect x="4" y="4" width="8" height="1" fill="#6ec8d8"/><rect x="4" y="11" width="8" height="1" fill="#3a6a78"/>
                <rect x="4" y="5" width="9" height="6" fill="#5ca8b8"/>
                <rect x="5" y="6" width="1" height="1" fill="#1a1f3c"/><rect x="7" y="6" width="1" height="1" fill="#1a1f3c"/>
                <rect x="13" y="5" width="1" height="1" fill="#6ec8d8"/><rect x="14" y="6" width="1" height="2" fill="#4a8a9a"/><rect x="13" y="8" width="1" height="1" fill="#3a6a78"/>
                <rect x="6" y="8" width="1" height="1" fill="#3a6a78"/>
            </svg>
            break;
        case "bag":
            <svg width="16" height="16" viewBox="0 0 16 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <rect x="5" y="2" width="6" height="1" fill="#c46e10"/><rect x="6" y="1" width="4" height="1" fill="#e8841a"/>
                <rect x="4" y="3" width="8" height="1" fill="#a05808"/>
                <rect x="3" y="4" width="10" height="9" fill="#7a5c3e"/>
                <rect x="4" y="4" width="8" height="1" fill="#9a7348"/><rect x="3" y="5" width="1" height="7" fill="#5c4033"/><rect x="12" y="5" width="1" height="7" fill="#4a3228"/>
                <rect x="4" y="12" width="8" height="1" fill="#4a3228"/>
                <rect x="6" y="7" width="4" height="3" fill="#5c4033"/>
                <rect x="7" y="8" width="2" height="1" fill="#f5a833"/>
            </svg>
