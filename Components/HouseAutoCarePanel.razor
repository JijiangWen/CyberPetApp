@using CyberPetApp.Models

<div class="auto-care-module">
    <div class="auto-care-head">
        <span class="section-lbl">auto.care // 智能护理模块</span>
        <span class="auto-care-meta">tick: 2s · daemon</span>
    </div>

    @if (FeederUnlocked || WatererUnlocked)
    {
        <div class="auto-care-unit settings" style="border: 1px solid var(--accent-dim, #3a4b5c); border-radius: 4px; padding: 12px; margin-bottom: 16px; background: rgba(20, 30, 40, 0.4);">
            <div class="auto-care-unit-head" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <PixelIcon Name="tool" />
                    <span class="auto-care-title" style="font-weight: bold; color: var(--text-color, #c8d6e5);">智能自动装填系统</span>
                </div>
                <span class="tag @(Player.AutoRefillUnlocked ? (Player.AutoRefillEnabled ? "on" : "off") : "off")" style="font-size: 10px; padding: 2px 6px; border-radius: 2px; font-family: monospace;">
                    @(Player.AutoRefillUnlocked ? (Player.AutoRefillEnabled ? "ACTIVE" : "PAUSED") : "LOCKED")
                </span>
            </div>
            @if (Player.AutoRefillUnlocked)
            {
                <div class="s-row" style="display: flex; align-items: center; justify-content: space-between; margin-top: 8px;">
                    <span class="s-label" style="color: var(--text-muted, #8a9baf);">自动装填功能</span>
                    <button type="button" class="g-btn" @onclick="OnToggleAutoRefill">
                        @(Player.AutoRefillEnabled ? "暂停自动装填" : "启用自动装填")
                    </button>
                </div>
                <p class="hint auto-care-hint" style="font-size: 11px; color: var(--text-dark, #5a6b7f); margin-top: 4px; line-height: 1.4;">
                    // 启用后：每 2s 自动将背包中的食物、饮料和凉白开水装填入槽（需加工费）
                </p>
            }
            else
            {
                <div class="s-row" style="display: flex; align-items: center; justify-content: space-between; margin-top: 8px;">
                    <span class="s-label" style="color: var(--text-muted, #8a9baf);">解锁自动装填</span>
                    <button type="button" class="g-btn primary" disabled="@(Player.Money < 1000)" @onclick="OnUnlockAutoRefill">
                        解锁(1000g)
                    </button>
                </div>
                <p class="hint auto-care-hint" style="font-size: 11px; color: var(--text-dark, #5a6b7f); margin-top: 4px; line-height: 1.4;">
                    // 一次性金币解锁。解锁后无需手动装填，后台将自动从背包补给食物和水
                </p>
            }
        </div>
    }

    @if (ShowFeeder)
    {
    @* ── 智能喂食站 ── *@
    <div class="auto-care-unit @(FeederUnlocked ? "active" : "locked")">
        <div class="auto-care-unit-head">
            <PixelIcon Name="bowl" />
            <span class="auto-care-title">智能喂食站</span>
            <span class="tag @(FeederUnlocked ? "on" : "off")">@(FeederUnlocked ? "ONLINE" : "LOCKED")</span>
        </div>
        @if (FeederUnlocked)
        {
            <div class="s-row">
                <span class="s-label">food</span>
                <code class="abar abar-food">@ProgressBar(Feeder.FoodCount, Feeder.MaxFoodCount)</code>
                <span class="s-val">@Feeder.FoodCount/@Feeder.MaxFoodCount</span>
            </div>
            <p class="hint auto-care-hint">
                // 饥饿&lt;600 或精力&lt;400 自动喂食 · 装粮 @EconomySinks.FeederProcessingFee g/份 · 容量 @Feeder.MaxFoodCount（基础10@(HouseBuffs.FeederExtraSlots > 0 ? $" +家具{HouseBuffs.FeederExtraSlots}" : "")）
            </p>
            <div class="auto-care-slots">
                @for (int i = 0; i < Feeder.MaxFoodCount; i++)
                {
                    var food = i < Feeder.Foods.Count ? Feeder.Foods[i] : null;
                    <div class="auto-care-slot @(food is not null ? "filled" : "empty")">
                        <span class="slot-idx">@i.ToString("D2")</span>
                        @if (food is not null)
                        {
                            <span class="slot-item">@food.Name</span>
                            <span class="slot-meta">♥@food.HungerRestore ⚡@food.EnergyRestore</span>
                        }
                        else
                        {
                            <span class="slot-empty">EMPTY</span>
                        }
                    </div>
                }
            </div>
            <div class="btn-group auto-care-actions">
                <button type="button" class="g-btn primary" disabled="@(!CanBatchFillFood())"
                        @onclick="OnBatchFillFood">
                    一键批量装填
                </button>
                <button type="button" class="g-btn" disabled="@(!HasBackpackFood(NormalFood.Name))"
                        @onclick="() => OnAddFood.InvokeAsync(NormalFood)">
                    <span class="item-sprite sp-24 item-food"></span>add(@NormalFood.Name)
                </button>
                <button type="button" class="g-btn" disabled="@(!HasBackpackFood(LuxuryFood.Name))"
                        @onclick="() => OnAddFood.InvokeAsync(LuxuryFood)">
                    <span class="item-sprite sp-24 item-can"></span>add(@LuxuryFood.Name)
                </button>
                @foreach (var item in GetFeederFoodsInBackpack().Where(x => x.Name != NormalFood.Name && x.Name != LuxuryFood.Name))
                {
                    <button type="button" class="g-btn" @onclick="() => OnAddFood.InvokeAsync(item.FoodObj)">
                        add(@item.Name)
                    </button>
                }
                @foreach (var cooked in CookBook.Recipes.Where(r => r.AllowAutoFeeder))
                {
                    @if (!GetFeederFoodsInBackpack().Any(x => x.Name == cooked.FoodName))
                    {
                        <button type="button" class="g-btn" disabled="@(!HasBackpackFood(cooked.FoodName))"
                                @onclick="() => OnAddCookedFood.InvokeAsync(cooked.FoodName)">
                            add(@cooked.FoodName)
                        </button>
                    }
                }
                <button type="button" class="g-btn" @onclick="OnRemoveFood">remove(last)</button>
            </div>
        }
        else
        {
            <p class="auto-care-locked-hint">// 购买 <strong>智能喂食站</strong> 家具后解锁</p>
        }
    </div>
    }

    @if (ShowWaterer)
    {
    @* ── 宠物饮水泉 ── *@
    <div class="auto-care-unit @(WatererUnlocked ? "active" : "locked")">
        <div class="auto-care-unit-head">
            <PixelIcon Name="bowl" />
            <span class="auto-care-title">宠物饮水泉</span>
            <span class="tag @(WatererUnlocked ? "on" : "off")">@(WatererUnlocked ? "ONLINE" : "LOCKED")</span>
        </div>
        @if (WatererUnlocked)
        {
            <div class="s-row">
                <span class="s-label">water</span>
                <code class="abar abar-thirst">@ProgressBar(Waterer.WaterCount, Waterer.MaxWaterCount)</code>
                <span class="s-val">@Waterer.WaterCount/@Waterer.MaxWaterCount</span>
            </div>
            <p class="hint auto-care-hint">
                // 口渴&lt;600 自动补水 · 槽空自来水 +@WaterCatalog.Tap.ThirstRestore/2s · 凉白开水 +@WaterCatalog.Purified.ThirstRestore · 装水 @EconomySinks.WatererProcessingFee g/份
            </p>
            <div class="auto-care-slots">
                @for (int i = 0; i < Waterer.MaxWaterCount; i++)
                {
                    var water = i < Waterer.Waters.Count ? Waterer.Waters[i] : null;
                    <div class="auto-care-slot @(water is not null ? "filled" : "empty")">
                        <span class="slot-idx">@i.ToString("D2")</span>
                        @if (water is not null)
                        {
                            <span class="slot-item">@water.Name</span>
                            <span class="slot-meta">💧+@water.ThirstRestore</span>
                        }
                        else
                        {
                            <span class="slot-empty">EMPTY</span>
                        }
                    </div>
                }
            </div>
            <div class="btn-group auto-care-actions">
                <button type="button" class="g-btn primary" disabled="@(!CanBatchFillWater())"
                        @onclick="OnBatchFillWater">
                    一键批量装填
                </button>
                <button type="button" class="g-btn" disabled="@(!HasBackpackWater())"
                        @onclick="OnAddWater">add(凉白开水)</button>
                <button type="button" class="g-btn" @onclick="OnRemoveWater">remove(last)</button>
            </div>
        }
        else
        {
            <p class="auto-care-locked-hint">// 购买 <strong>宠物饮水泉</strong> 家具后解锁</p>
        }
    </div>
    }

    @if (ShowPassive)
    {
    @* ── 被动家具 ── *@
    @foreach (var entry in PassiveFurniture)
    {
        <div class="auto-care-unit passive @(entry.Unlocked ? "active" : "locked")">
            <div class="auto-care-unit-head">
                <PixelIcon Name="cat" />
                <span class="auto-care-title">@entry.DisplayName</span>
                <span class="tag @(entry.Unlocked ? "on" : "off")">@(entry.Unlocked ? "生效中" : "LOCKED")</span>
            </div>
            @if (entry.Unlocked && entry.PassiveLabel is not null)
            {
                <p class="hint auto-care-hint">// passive: @((MarkupString)entry.PassiveLabel)</p>
            }
            else if (!entry.Unlocked)
            {
                <p class="auto-care-locked-hint">// 购买 <strong>@entry.DisplayName</strong> 家具后解锁</p>
            }
        </div>
    }
    }

    @if (Message is not null)
    {
        <p class="hint auto-care-msg">// @Message</p>
    }
</div>

@code {
    public record PassiveFurnitureEntry(string FurnitureId, string DisplayName, bool Unlocked, string? PassiveLabel);

    [Parameter, EditorRequired] public Player Player { get; set; } = null!;
    [Parameter, EditorRequired] public AutoFeeder Feeder { get; set; } = null!;
    [Parameter, EditorRequired] public AutoWaterer Waterer { get; set; } = null!;
    [Parameter, EditorRequired] public Food NormalFood { get; set; } = null!;
    [Parameter, EditorRequired] public Food LuxuryFood { get; set; } = null!;
    [Parameter] public HouseBuffs HouseBuffs { get; set; }
    [Parameter] public Dictionary<string, int> Backpack { get; set; } = [];
    [Parameter] public bool FeederUnlocked { get; set; }
    [Parameter] public bool WatererUnlocked { get; set; }
    [Parameter] public IReadOnlyList<PassiveFurnitureEntry> PassiveFurniture { get; set; } = [];
    [Parameter] public string? Message { get; set; }
    [Parameter] public bool ShowFeeder { get; set; } = true;
    [Parameter] public bool ShowWaterer { get; set; } = true;
    [Parameter] public bool ShowPassive { get; set; } = true;

    [Parameter] public EventCallback<Food> OnAddFood { get; set; }
    [Parameter] public EventCallback<string> OnAddCookedFood { get; set; }
    [Parameter] public EventCallback OnRemoveFood { get; set; }
    [Parameter] public EventCallback OnAddWater { get; set; }
    [Parameter] public EventCallback OnRemoveWater { get; set; }
    [Parameter] public EventCallback OnBatchFillFood { get; set; }
    [Parameter] public EventCallback OnBatchFillWater { get; set; }
    [Parameter] public EventCallback OnUnlockAutoRefill { get; set; }
    [Parameter] public EventCallback OnToggleAutoRefill { get; set; }

    private bool CanBatchFillFood()
    {
        if (Feeder.FoodCount >= Feeder.MaxFoodCount) return false;
        var shop = new Shop();
        return Backpack.Keys.Any(name => FeederService.TryGetFeederFood(name, shop, out _));
    }

    private bool CanBatchFillWater()
    {
        if (Waterer.WaterCount >= Waterer.MaxWaterCount) return false;
        return Backpack.GetValueOrDefault(WaterCatalog.Purified.Name) > 0;
    }

    private IEnumerable<(string Name, int Qty, Food FoodObj)> GetFeederFoodsInBackpack()
    {
        var shop = new Shop();
        foreach (var kvp in Backpack)
        {
            if (FeederService.TryGetFeederFood(kvp.Key, shop, out var food) && food is not null)
            {
                yield return (kvp.Key, kvp.Value, food);
            }
        }
    }

    private bool HasBackpackFood(string name) =>
        Backpack.GetValueOrDefault(name) > 0;

    private bool HasBackpackWater() =>
        Backpack.GetValueOrDefault(WaterCatalog.Purified.Name) > 0;

    private static string ProgressBar(int value, int max, int width = 10)
    {
        var filled = Math.Clamp((int)Math.Round((double)value / Math.Max(1, max) * width), 0, width);
        return new string('█', filled) + new string('░', width - filled);
    }
}
